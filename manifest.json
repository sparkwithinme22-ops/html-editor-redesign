{
  "manifest_version": 3,
  "name": "HTML Editor",
  "version": "1.0",
  "description": "Edit and preview HTML, CSS, and JavaScript.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}